# OpenAI (required for the legacy POST /predict endpoint; not used by M1's new endpoints)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_MAX_OUTPUT_TOKENS=400

# MLflow is OFF by default for local development.
# Leave both values blank to disable MLflow entirely (no remote connections, no logging anywhere).
# To opt in later, set MLFLOW_TRACKING_URI to your own tracking server URL.
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=

# Database (Postgres running via docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/deal_room_ai

# JWT / auth
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_COOKIE_NAME=deal_room_ai_session
JWT_EXPIRE_DAYS=7

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Document storage (bind-mounted into the api container)
STORAGE_DIR=./storage
MAX_UPLOAD_BYTES=10485760

# Embeddings (only used when OPENAI_API_KEY is set; no network calls in tests)
EMBEDDING_MODEL=text-embedding-3-small

# Chroma (local server via docker-compose)
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=deal_room_ai_chunks
