# ============================================================================
# Deal Room AI — local development environment template
# ============================================================================
# Local development is OFFLINE / FREE by default. No call to OpenAI, Gemini,
# Vertex AI, GCP, GitHub, or external MLflow happens unless you explicitly
# opt in via the ENABLE_* flags below AND provide the matching credentials.
# Tests are designed to never reach the network regardless of these flags.
# ============================================================================

# --- Cost / cloud feature flags (offline by default) ------------------------
# Master kill-switch for any LLM / embedding call to OpenAI. Even when an
# OPENAI_API_KEY is set below, no OpenAI client is constructed and no
# network call is attempted unless this flag is true.
ENABLE_LLM_CALLS=false

# Master kill-switch for MLflow logging. Even when MLFLOW_TRACKING_URI is
# set below, no MLflow client is configured unless this flag is true.
ENABLE_MLFLOW=false

# Guard for the offline ingestion CLI (`python -m ingestion.pipeline`). The
# CLI refuses to run unless this is true. Library-level imports of
# ingestion.pipeline are not affected.
ENABLE_EXTERNAL_INGESTION=false

# --- OpenAI -----------------------------------------------------------------
# Used by /ask, /analyze, /chat, document embeddings, and the legacy
# /predict route. Must be combined with ENABLE_LLM_CALLS=true to actually
# call OpenAI. Leave blank to keep all OpenAI paths fully disabled.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_MAX_OUTPUT_TOKENS=400

# --- MLflow -----------------------------------------------------------------
# OFF by default for local development. Leave both values blank to disable
# MLflow entirely (no remote connections, no logging anywhere). To opt in,
# set BOTH ENABLE_MLFLOW=true and MLFLOW_TRACKING_URI to your tracking
# server URL.
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=

# --- Database (Postgres running via docker-compose) -------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/deal_room_ai

# --- JWT / auth -------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_COOKIE_NAME=deal_room_ai_session
JWT_EXPIRE_DAYS=7
# Cookie security flag. Set false for local HTTP development (default).
# Set true ONLY when serving the API behind HTTPS in production; browsers
# will refuse to send a Secure cookie over plain HTTP.
JWT_COOKIE_SECURE=false

# --- CORS -------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000

# --- Document storage (bind-mounted into the api container) ----------------
STORAGE_DIR=./storage
MAX_UPLOAD_BYTES=10485760

# --- Embeddings (only used when ENABLE_LLM_CALLS=true and key is set) ------
EMBEDDING_MODEL=text-embedding-3-small

# --- Chroma (local server via docker-compose) -------------------------------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=deal_room_ai_chunks
